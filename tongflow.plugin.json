{
    "plugin": {
        "name": "APIMart",
        "description": "OpenAI-compatible aggregation gateway — one key routes to many upstream image/text/video models (GPT, Claude, Gemini, Seedream, Sora, …).",
        "icon": "/plugins/tongflow-api-apimart.svg"
    },
    "env": [
        {
            "key": "APIMART_API_KEY",
            "required": true,
            "description": "APIMart API key",
            "url": "https://apimart.ai"
        },
        {
            "key": "APIMART_BASE_URL",
            "default": "https://api.apimart.ai",
            "description": "Override the APIMart endpoint"
        },
        {
            "key": "APIMART_POLL_TIMEOUT_S",
            "default": "600",
            "description": "Max seconds to wait for an async task"
        }
    ]
}
